# Gmail account used for IMAP/SMTP testing
TASK_EMAIL=your_gmail@gmail.com

# Use a 16-character Google App Password, not your normal Gmail password
TASK_PASSWORD=your_16_char_app_password

# Local MongoDB defaults for Docker compose
MONGODB_URI=mongodb://admin:admin1234@localhost:27017/mail2task?authSource=admin
MONGODB_DB=mail2task
MONGODB_MAILS_COLLECTION=mails
MONGODB_TASKS_COLLECTION=tasks

# Optional for your later LLM summary work
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
